# Production Environment Variables
# Add these to Vercel Dashboard → Project Settings → Environment Variables

# Database - MUST be production PostgreSQL
DATABASE_URL=postgresql://user:password@prod-db-host.com:5432/orith

# Authentication
JWT_SECRET=your_production_jwt_secret_here_min_32_chars

# Public API URL - This is the URL of your Vercel deployment
NEXT_PUBLIC_API_URL=https://orith.vercel.app
