# ── Frontend (Next.js) environment ──
# The backend (auth, products, orders, checkout, payments, webhooks) now lives
# in the standalone NestJS app under /backend. The frontend only needs the
# public vars below; all secrets (DB, JWT, Paymob, shipping fees) live in
# backend/.env.

# Base URL of the NestJS backend. All /api/* calls are sent here (CORS).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public app config (safe to expose to the browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=150000   # piastres (150000 = 1500 EGP)
NEXT_PUBLIC_STORE_NAME=ORITH
