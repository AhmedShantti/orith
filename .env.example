# Database
DATABASE_URL=postgresql://user:password@localhost:5432/orith

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Public API URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Paymob Configuration (NEVER expose to client — server-side only)
# ─────────────────────────────────────────────────────────────
PAYMOB_API_KEY=your_paymob_api_key_here
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret_here
PAYMOB_MOBILE_WALLET_INTEGRATION_ID=your_mobile_wallet_integration_id
PAYMOB_APPLE_PAY_INTEGRATION_ID=your_apple_pay_integration_id
PAYMOB_APPLE_PAY_IFRAME_ID=your_apple_pay_iframe_id

# ─────────────────────────────────────────────────────────────
# Public App Config (safe to expose)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=150000   # piastres (150000 = 1500 EGP)
NEXT_PUBLIC_STORE_NAME=ORITH

# ─────────────────────────────────────────────────────────────
# Shipping Fees (server-side only — cannot be manipulated by client)
# ─────────────────────────────────────────────────────────────
SHIPPING_FEE_CAIRO_GIZA=5000                 # piastres (5000 = 50 EGP)
SHIPPING_FEE_OTHER=8000                      # piastres (8000 = 80 EGP)
# TAX_RATE=0                                  # reserved for future use
