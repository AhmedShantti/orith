# ── Backend (NestJS) environment ──

# Same PostgreSQL database as the Prisma schema in this repo
DATABASE_URL=postgresql://user:password@localhost:5432/orith

# JWT — MUST match the value the frontend/old backend used so tokens stay valid
JWT_SECRET=your_jwt_secret_here

# Server
PORT=4000
# Comma-separated list of allowed frontend origins (CORS)
FRONTEND_ORIGIN=http://localhost:3000

# Where uploaded product images are written (defaults to ../public/products)
# UPLOAD_DIR=/absolute/path/to/orith/public/products

# ── Paymob (server-side only) ──
PAYMOB_API_KEY=your_paymob_api_key_here
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret_here
PAYMOB_MOBILE_WALLET_INTEGRATION_ID=your_mobile_wallet_integration_id
PAYMOB_APPLE_PAY_INTEGRATION_ID=your_apple_pay_integration_id
PAYMOB_APPLE_PAY_IFRAME_ID=your_apple_pay_iframe_id

# ── Commerce config ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=150000
NEXT_PUBLIC_STORE_NAME=ORITH
SHIPPING_FEE_CAIRO_GIZA=5000
SHIPPING_FEE_OTHER=8000
